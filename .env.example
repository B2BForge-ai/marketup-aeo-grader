DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 可选模型：deepseek-chat（默认）| deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-chat

# Supabase PostgreSQL
# Vercel / 生产环境请用 Transaction pooler（6543），不要用直连 5432
# Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
# 本地开发若 5432 连不上，同样改用上方 pooler 连接串

# Mailgun 邮件服务（发件域名 email.b2bforge.ai）
MAILGUN_API_KEY=your_mailgun_private_api_key
MAILGUN_DOMAIN=email.b2bforge.ai
MAILGUN_FROM_EMAIL=MarketUP GEO <noreply@email.b2bforge.ai>
# 可选：美区 api.mailgun.net（默认）| 欧区填 eu
# MAILGUN_REGION=eu

# MarketUP 短信验证码（与官网表单共用 /api/open/auth/code）
MARKETUP_API_BASE_URL=https://www.marketup.cn
MARKETUP_API_REFERER=https://www.marketup.cn/

# 管理员审核后台 Token（访问 /admin/reports?token=YOUR_TOKEN）
ADMIN_SECRET_TOKEN=your_admin_secret_here

# 站点公网地址（邮件中报告专属链接用，部署 Vercel 时填 https://your-domain.vercel.app）
NEXT_PUBLIC_APP_URL=http://localhost:3000
