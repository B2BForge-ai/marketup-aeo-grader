DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 可选模型：deepseek-chat（默认）| deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-chat

# Supabase PostgreSQL（Project Settings → Database → Connection string）
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Resend 邮件服务（企业邮箱 OTP + 深度报告发送）
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=MarketUP GEO <noreply@yourdomain.com>

# 管理员审核后台 Token（访问 /admin/reports?token=YOUR_TOKEN）
ADMIN_SECRET_TOKEN=your_admin_secret_here

# 站点公网地址（邮件中报告专属链接用，部署 Vercel 时填 https://your-domain.vercel.app）
NEXT_PUBLIC_APP_URL=http://localhost:3000
